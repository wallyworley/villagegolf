# Copy this to .env for local testing (never commit .env to git)

# PIN to access the web app (choose any 4+ digit number)
APP_PIN=your_chosen_pin

# A long random string for Flask session security
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_long_random_string

# Set to false to watch the browser during local debugging
# HEADLESS=false

# ── Credentials-at-rest encryption (REQUIRED in production) ────────────────────
# User profiles hold Villages passwords + PINs, so the DB is encrypted at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
USER_DB_ENCRYPTION_KEY=replace_with_a_fernet_key
# Local dev only: skip encryption instead of setting a key (never in production).
# ALLOW_PLAINTEXT_USER_DB=1

# ── Cookies / proxy ───────────────────────────────────────────────────────────
# Session cookie Secure flag is ON by default. Local http dev must turn it off:
# SESSION_COOKIE_SECURE=0
# Trust one hop of X-Forwarded-For/-Proto (Caddy). Set 0 if no proxy is in front.
# TRUST_PROXY=1

# ── Ops / alerting (optional) ─────────────────────────────────────────────────
# Email address to notify when the browser worker errors or wedges.
# OPERATOR_ALERT_EMAIL=you@example.com
# Seconds before a wedged worker self-terminates for a clean restart (default 280).
# WORKER_WATCHDOG_SECONDS=280
# Warm browser-session pool size (default 4) and mid-shopping protection window.
# MAX_BROWSER_SESSIONS=4
# SESSION_PROTECT_SECONDS=300
